# Required: Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Ethereum RPC URL (free options below)
# Public (no key): https://eth.llamarpc.com
# Alchemy (recommended): https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL=https://eth.llamarpc.com

# Optional: Etherscan API key for contract ABI lookups
# Get free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Optional: Vertex AI instead of AI Studio
USE_VERTEX=false
GCP_PROJECT=
